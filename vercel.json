{
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" },
    { "src": "backend/*.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/api/sim/(.*)", "destination": "/backend/Simulation_System.py" },
    { "source": "/api/space/(.*)", "destination": "/backend/Space_Data_Center.py" },
    { "source": "/api/dash/(.*)", "destination": "/backend/Mission_Dashboard.py" },
    { "source": "/", "destination": "/frontend/DeepSpace%20Survival%20Simulator.html" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}